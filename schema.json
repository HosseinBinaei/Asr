                "password",
                "email",
                "first_name"
            ],
            "type": "object",
            "properties": {
                "password": {
                    "title": "Password",
                    "type": "string",
                    "minLength": 1
                },
                "email": {
                    "title": "Email",
                    "type": "string",
                    "format": "email",
                    "minLength": 1
                },
                "first_name": {
                    "title": "First name",
                    "type": "string",
                    "maxLength": 150,
                    "minLength": 1
                },
                "last_name": {
                    "title": "Last name",
                    "type": "string",
                    "maxLength": 150
                }
            }
        },
        "TokenRefresh": {
            "required": [
                "refresh"
            ],
            "type": "object",
            "properties": {
                "refresh": {
                    "title": "Refresh",
                    "type": "string",
                    "minLength": 1
                },
                "access": {
                    "title": "Access",
                    "type": "string",
                    "readOnly": true,
                    "minLength": 1
                }
            }
        },
        "Elapsed": {
            "required": [
                "now",
                "elapsed"
            ],
            "type": "object",
            "properties": {
                "now": {
                    "title": "Now",
                    "type": "object"
                },
                "elapsed": {
                    "title": "Elapsed",
                    "type": "object"
                }
            }
        },
        "Note": {
            "required": [
                "title",
                "content",
                "created_at"
            ],
            "type": "object",
            "properties": {
                "id": {
                    "title": "ID",
                    "type": "integer",
                    "readOnly": true
                },
                "title": {
                    "title": "Title",
                    "type": "string",
                    "maxLength": 255,
                    "minLength": 1
                },
                "content": {
                    "title": "Content",
                    "type": "string",
                    "minLength": 1
                },
                "note_type": {
                    "title": "Note type",
                    "type": "string",
                    "enum": [
                        "note",
                        "reminder"
                    ]
                },
                "created_at": {
                    "title": "Created at",
                    "type": "string",
                    "minLength": 1
                }
